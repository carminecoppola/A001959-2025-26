<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calc_background"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:ellipsize="start"
        android:gravity="end|center_vertical"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:text="@string/display_initial_value"
        android:textColor="@color/calc_display_text"
        android:textSize="54sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/guidelineButtonsTop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineButtonsTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.30" />

    <android.widget.GridLayout
        android:id="@+id/buttonGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="4"
        android:rowCount="5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guidelineButtonsTop">

        <Button android:id="@+id/btnClear" style="@style/CalcButton.Gray" android:text="@string/button_clear" android:layout_column="0" android:layout_row="0" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnToggleSign" style="@style/CalcButton.Gray" android:text="@string/button_toggle_sign" android:layout_column="1" android:layout_row="0" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnPercent" style="@style/CalcButton.Gray" android:text="@string/button_percent" android:layout_column="2" android:layout_row="0" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnDivide" style="@style/CalcButton.Orange" android:text="@string/button_divide" android:layout_column="3" android:layout_row="0" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />

        <Button android:id="@+id/btn7" style="@style/CalcButton" android:text="7" android:layout_column="0" android:layout_row="1" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn8" style="@style/CalcButton" android:text="8" android:layout_column="1" android:layout_row="1" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn9" style="@style/CalcButton" android:text="9" android:layout_column="2" android:layout_row="1" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnMultiply" style="@style/CalcButton.Orange" android:text="@string/button_multiply" android:layout_column="3" android:layout_row="1" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />

        <Button android:id="@+id/btn4" style="@style/CalcButton" android:text="4" android:layout_column="0" android:layout_row="2" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn5" style="@style/CalcButton" android:text="5" android:layout_column="1" android:layout_row="2" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn6" style="@style/CalcButton" android:text="6" android:layout_column="2" android:layout_row="2" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnSubtract" style="@style/CalcButton.Orange" android:text="@string/button_subtract" android:layout_column="3" android:layout_row="2" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />

        <Button android:id="@+id/btn1" style="@style/CalcButton" android:text="1" android:layout_column="0" android:layout_row="3" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn2" style="@style/CalcButton" android:text="2" android:layout_column="1" android:layout_row="3" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn3" style="@style/CalcButton" android:text="3" android:layout_column="2" android:layout_row="3" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnAdd" style="@style/CalcButton.Orange" android:text="@string/button_add" android:layout_column="3" android:layout_row="3" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />

        <Button android:id="@+id/btn0" style="@style/CalcButton" android:text="0" android:layout_column="0" android:layout_columnSpan="2" android:layout_row="4" android:layout_columnWeight="2" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnDecimal" style="@style/CalcButton" android:text="@string/button_decimal" android:layout_column="2" android:layout_row="4" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnEquals" style="@style/CalcButton.Orange" android:text="@string/button_equals" android:layout_column="3" android:layout_row="4" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill" />

    </android.widget.GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>