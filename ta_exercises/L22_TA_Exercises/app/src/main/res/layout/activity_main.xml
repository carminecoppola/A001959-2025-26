<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lesson 22 - Authentication &amp; Biometrics"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BiometricPrompt, CryptoObject, OAuth2 PKCE and secure token handling"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonCheckBiometrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check Biometric Availability"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/buttonStoreToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Encrypt Demo Refresh Token"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonUnlockToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unlock Token with Biometrics"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonShowPkce"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show OAuth2 PKCE Summary"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/textViewOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Output will appear here."
            android:textSize="16sp"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</ScrollView>