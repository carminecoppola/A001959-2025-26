<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lesson 20 - Secure Data Storage"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editTextSecret"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Insert secret text"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/buttonSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Encrypt &amp; Save"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/buttonRead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Read &amp; Decrypt"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/buttonTamper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tamper File"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/textViewOutput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Output"
        android:layout_marginTop="24dp"
        android:textSize="16sp"/>

</LinearLayout>