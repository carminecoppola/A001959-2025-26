<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lesson 21 - Network Security"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="HTTPS, Network Security Config and Certificate Pinning"
        android:textSize="16sp"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/buttonHttpsRequest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Run HTTPS Request"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/buttonPinnedRequest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Run Pinned HTTPS Request"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/buttonHttpRequest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Try Plain HTTP Request"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/textViewOutput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Output will appear here."
        android:textSize="16sp"
        android:layout_marginTop="24dp" />

</LinearLayout>