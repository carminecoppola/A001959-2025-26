<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lesson 24 - Secure Release Checklist"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Production hardening, R8, signing, CI/CD and rollout monitoring"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonRunChecklist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Run Pre-Release Checklist"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/buttonShowSigning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show App Signing Notes"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonShowCiCd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show CI/CD Pipeline"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonShowBugs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show 3 Release Bugs"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/buttonShowTesting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show How To Test"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/textViewOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Output will appear here."
            android:textSize="16sp"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</ScrollView>