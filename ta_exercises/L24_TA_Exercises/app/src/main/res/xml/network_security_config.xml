<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!--
        Cleartext traffic is disabled globally.
        This is coherent with the secure release checklist:
        production applications should not allow plain HTTP traffic.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!--
                Trust only system Certificate Authorities in production.
                User-installed CAs should not be trusted unless explicitly needed
                for debug builds.
            -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>