<?xml version="1.0" encoding="utf-8"?>
<!--
    Main layout for the Coroutines and Flow demonstration.
    The Activity renders StateFlow values and SharedFlow events.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!--
        Vertical container centered for classroom readability.
    -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintWidth_percent="0.90"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
            Title of the lesson demo.
        -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Coroutines &amp; Flow Demo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <!--
            Short academic description.
        -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="StateFlow stores state; SharedFlow emits one-shot events."
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <!--
            Counter value collected from StateFlow.
        -->
        <TextView
            android:id="@+id/tvCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <!--
            Explains the latest StateFlow value.
        -->
        <TextView
            android:id="@+id/tvStateDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="StateFlow current value: 0"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <!--
            Increments the StateFlow value.
        -->
        <Button
            android:id="@+id/btnIncrement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Increment"
            android:layout_marginBottom="12dp" />

        <!--
            Decrements the StateFlow value with error handling.
        -->
        <Button
            android:id="@+id/btnDecrement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Decrement"
            android:layout_marginBottom="12dp" />

        <!--
            Resets the StateFlow value.
        -->
        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:layout_marginBottom="12dp" />

        <!--
            Demonstrates a coroutine using delay without blocking the UI thread.
        -->
        <Button
            android:id="@+id/btnBackgroundWork"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simulate Background Work"
            android:layout_marginBottom="24dp" />

        <!--
            Shows the last one-shot event emitted through SharedFlow.
        -->
        <TextView
            android:id="@+id/tvLastEvent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last SharedFlow event: none"
            android:textSize="16sp"
            android:textAlignment="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>