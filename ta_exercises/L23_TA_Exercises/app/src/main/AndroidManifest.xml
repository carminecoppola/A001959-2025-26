<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        No INTERNET permission is declared because this demo focuses on local
        OWASP Mobile Top 10 checks and does not need network access.
    -->

    <application
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:label="@string/app_name"
        android:theme="@style/Theme.L23OwaspMobileTop10">

        <!--
            This Activity is exported only because it is the launcher Activity.
            Non-launcher components should be exported=false by default.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>