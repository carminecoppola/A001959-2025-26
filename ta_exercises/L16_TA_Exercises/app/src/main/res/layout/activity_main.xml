<?xml version="1.0" encoding="utf-8"?>
<!--
    Main layout for the SharedPreferences demonstration.
    The UI allows the user to save, load and clear small settings.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!--
        Vertical content container centered on the screen.
    -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintWidth_percent="0.90"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
            Title of the classroom demo.
        -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SharedPreferences Demo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <!--
            Short explanation of what is being demonstrated.
        -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save and load small key-value settings using SharedPreferences."
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <!--
            Username is stored as a String preference.
        -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username"
            android:inputType="textPersonName"
            android:singleLine="true"
            android:layout_marginBottom="16dp" />

        <!--
            Dark mode is stored as a Boolean preference.
            This demo stores the value but does not change the app theme.
        -->
        <Switch
            android:id="@+id/switchDarkMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dark mode enabled"
            android:layout_marginBottom="24dp" />

        <!--
            Saves current UI values into SharedPreferences.
        -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Preferences"
            android:layout_marginBottom="12dp" />

        <!--
            Loads current values from SharedPreferences.
        -->
        <Button
            android:id="@+id/btnLoad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load Preferences"
            android:layout_marginBottom="12dp" />

        <!--
            Clears all keys in this SharedPreferences file.
        -->
        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear Preferences"
            android:layout_marginBottom="24dp" />

        <!--
            Shows operation feedback.
        -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preferences not loaded yet."
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <!--
            Shows a readable summary of the stored settings.
        -->
        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Username: not set&#10;Dark mode: false"
            android:textSize="16sp"
            android:textAlignment="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>